  "description": "Backend API for MCQ Exam Portal with Firebase Auth and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "node setup-database.js",
    "setup-db": "node setup-database.js",
    "verify": "node verify-setup.js",
    "verify-setup": "node verify-setup.js",
    "load-dummy-data": "node load-dummy-data.js",
    "test": "jest",
    "pm2:start": "pm2 start ecosystem.config.js",
