    "pm2:restart": "pm2 restart mcq-backend",
    "pm2:delete": "pm2 delete mcq-backend",
    "pm2:logs": "pm2 logs mcq-backend",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
