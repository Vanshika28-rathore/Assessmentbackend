PORT=5000
NODE_ENV=development

DB_NAME="Shnoor_Assignment_Portal"
DB_USER="postgres"
DB_PASSWORD="Praveen@2003"
DB_HOST="localhost"
DB_PORT=5432
DB_SSL=false

# Firebase Configuration
# Place your serviceAccountKey.json in the backend folder
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# CORS Configuration (Your React Frontend URL)
CLIENT_URL=http://localhost:5173

# JWT Secret for Admin Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Database Pool Configuration (for 300+ concurrent users)
DB_POOL_MAX=100

# Redis Configuration (for caching and session management)
# Use WSL IP address when running Redis in WSL and Node.js in Windows
REDIS_URL=redis://172.27.127.40:6379

# Proctoring Configuration (Sample-Based Monitoring)
PROCTORING_SAMPLE_RATE=0.15        # 15% of students monitored (0.10 = 10%, 0.20 = 20%)
PROCTORING_FRAME_RATE=2            # Frames per second (2 FPS recommended)
PROCTORING_ROTATION_MINUTES=5      # Rotate monitored students every N minutes


